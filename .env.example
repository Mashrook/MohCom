# MohCom environment example
# انسخ هذا الملف إلى .env أو أضف القيم إلى Railway Variables

# Public app URLs
SITE_URL=https://mohcom-production.up.railway.app
PUBLIC_SITE_URL=https://mohcom-production.up.railway.app
RAILWAY_PUBLIC_DOMAIN=mohcom-production.up.railway.app

# Supabase
VITE_SUPABASE_PROJECT_ID=glmpsmwcbxebxioekgzu
VITE_SUPABASE_URL=https://glmpsmwcbxebxioekgzu.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# AI provider
# Supported values: openai, openrouter, gemini, custom
AI_PROVIDER=openai
AI_MODEL=gpt-4o-mini
AI_API_KEY=your-ai-api-key
AI_API_BASE_URL=

# Optional provider-specific fallbacks
OPENAI_API_KEY=
OPENAI_MODEL=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
GOOGLE_GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Payments
VITE_MOYASAR_URL=https://api.moyasar.com/v1
MOYASAR_PUBLISHABLE_KEY=your-moyasar-publishable-key
MOYASAR_SECRET_KEY=your-moyasar-secret-key

# Search and email
PERPLEXITY_API_KEY=
RESEND_API_KEY=

# Maps and RTC
VITE_MAPBOX_TOKEN=
MAPBOX_PUBLIC_TOKEN=
VITE_JAAS_APP_ID=
JITSI_APP_ID=
JITSI_PRIVATE_KEY=
VITE_GOOGLE_OAUTH_CLIENT_ID=

# Notes
# المتغيرات التي تبدأ بـ VITE_ متاحة للواجهة الأمامية
# لا تحفظ أي مفاتيح سرية حقيقية داخل Git
